<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>AR Selfie 9:16 - Diego Capani</title>
    <script src="https://aframe.io/releases/1.3.0/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar.js"></script>
    
    <style>
        #btn-scatto {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
            z-index: 1000; width: 80px; height: 80px; background: white;
            border-radius: 50%; border: 5px solid #000; cursor: pointer;
            box-shadow: 0 0 15px rgba(0,0,0,0.4);
        }
        #btn-scatto:active { background: #ff4444; }
    </style>
</head>

<body style="margin: 0px; overflow: hidden;">

    <div id="btn-scatto"></div>

    <a-scene embedded 
             renderer="preserveDrawingBuffer: true; alpha: true;" 
             arjs="sourceType: webcam; detectionMode: mono_and_matrix; matrixCodeType: 3x3; debugUIEnabled: false;">

        <a-assets>
            <a-asset-item id="modello-1" src="man.glb"></a-asset-item>
        </a-assets>

        <a-marker type="barcode" value="1">
            <a-entity gltf-model="#modello-1" scale="6 6 6" position="0 0 0" rotation="0 90 0"></a-entity>
        </a-marker>

        <a-entity camera></a-entity>
    </a-scene>

    <script>
        document.getElementById('btn-scatto').addEventListener('click', function() {
            const scene = document.querySelector('a-scene');
            const video = document.querySelector('#arjs-video');
            const canvasAR = scene.canvas;

            // 1. FORZIAMO IL FORMATO 9:16 (Standard Social)
            // Impostiamo una risoluzione alta (es. 1080x1920)
            const outW = 1080;
            const outH = 1920;
            
            const fotoCanvas = document.createElement('canvas');
            fotoCanvas.width = outW;
            fotoCanvas.height = outH;
            const ctx = fotoCanvas.getContext('2d');

            // 2. CALCOLO RITAGLIO WEBCAM (Crop centrale per 9:16)
            const vW = video.videoWidth;
            const vH = video.videoHeight;
            const targetRatio = outW / outH; // 0.5625
            const videoRatio = vW / vH;

            let sx, sy, sw, sh;
            if (videoRatio > targetRatio) {
                sw = vH * targetRatio;
                sh = vH;
                sx = (vW - sw) / 2;
                sy = 0;
            } else {
                sw = vW;
                sh = vW / targetRatio;
                sx = 0;
                sy = (vH - sh) / 2;
            }

            // Disegna lo sfondo (Realtà)
            ctx.drawImage(video, sx, sy, sw, sh, 0, 0, outW, outH);

            // 3. CALCOLO RITAGLIO SCENA 3D (Per farla coincidere con la webcam)
            const cW = canvasAR.width;
            const cH = canvasAR.height;
            const canvasRatio = cW / cH;

            let cx, cy, cw, ch;
            if (canvasRatio > targetRatio) {
                cw = cH * targetRatio;
                ch = cH;
                cx = (cW - cw) / 2;
                cy = 0;
            } else {
                cw = cW;
                ch = cW / targetRatio;
                cx = 0;
                cy = (cH - ch) / 2;
            }

            // Forza il rendering del 3D
            scene.renderer.render(scene.object3D, scene.camera);
            
            // Disegna il soggetto sopra (Livello AR)
            ctx.drawImage(canvasAR, cx, cy, cw, ch, 0, 0, outW, outH);

            // 4. SALVATAGGIO UNICO (Timestamp)
            const timestamp = Date.now();
            const link = document.createElement('a');
            link.download = `AR_916_Selfie_${timestamp}.png`;
            link.href = fotoCanvas.toDataURL("image/png");
            link.click();
        });
    </script>
</body>
</html>
